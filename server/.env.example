# ── Application ──
NODE_ENV=production
PORT=5000

# ── MongoDB ──
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority

# ── JWT ──
JWT_SECRET=<generate-a-strong-random-secret>
JWT_EXPIRES_IN=30m

# ── Gemini AI ──
GEMINI_API_KEY=<your-gemini-api-key>

# ── Services URLs (set to deployed Render URLs) ──
PYTHON_AI_URL=https://ai-interview-python-ai.onrender.com
AVATAR_SERVICE_URL=https://ai-interview-avatar-service.onrender.com

# ── Client URL (CORS — set to your Vercel deployment URL) ──
CLIENT_URL=https://your-app.vercel.app

# ── File Uploads ──
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# ── Cloudinary (resume/logo uploads) ──
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>

# ── Resume Processing ──
MAX_RESUME_SIZE_MB=5

# ── N8N Webhooks ──
N8N_WEBHOOK_REGISTRATION=https://<your-n8n-host>/webhook/registration
N8N_WEBHOOK_RESUME_REJECTED=https://<your-n8n-host>/webhook/resume-rejected
N8N_WEBHOOK_INTERVIEW_SCHEDULED=https://<your-n8n-host>/webhook/interview-scheduled
N8N_WEBHOOK_INTERVIEW_REMINDER=https://<your-n8n-host>/webhook/interview-reminder
N8N_WEBHOOK_INTERVIEW_COMPLETE=https://<your-n8n-host>/webhook/interview-complete
N8N_WEBHOOK_OFFER=https://<your-n8n-host>/webhook/offer
